### ===================================================
### Auth endpoints
### ===================================================

@baseUrl = http://localhost:8000

### Login (captures token for use in other requests)
# @name loginRequest
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin"
}

### Refresh token
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refresh_token": "{{loginRequest.response.body.refresh_token}}"
}

### Get current user
GET {{baseUrl}}/auth/me
Authorization: Bearer {{loginRequest.response.body.access_token}}

### Update current user
PUT {{baseUrl}}/auth/me
Authorization: Bearer {{loginRequest.response.body.access_token}}
Content-Type: application/json

{
  "nombre": "Dr. Admin Updated"
}

### Create new user (admin only)
POST {{baseUrl}}/auth/users
Authorization: Bearer {{loginRequest.response.body.access_token}}
Content-Type: application/json

{
  "username": "newdoctor",
  "password": "doctor123",
  "nombre": "Dr. New",
  "is_admin": false
}

### List all users (admin only)
GET {{baseUrl}}/auth/users
Authorization: Bearer {{loginRequest.response.body.access_token}}
