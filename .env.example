# Database
DATABASE_URL=postgresql://tcoffline:tcoffline@localhost:5432/tcoffline

# Environment
ENVIRONMENT=development

# TrakCare Central Server
CENTRAL_URL=http://[Server IP or Hostname]
CENTRAL_API_ENDPOINT=/[instance]/tcoffline/getData
CENTRAL_HL7_ENDPOINT=/[instance]/tcoffline/hl7inbound
CENTRAL_API_USERNAME=[username]
CENTRAL_API_PASSWORD=[password]

# Sync Configuration
AUTO_SYNC_ENABLED=true
HEALTH_CHECK_INTERVAL=8
DOWNSTREAM_SYNC_INTERVAL=60
UPSTREAM_SYNC_INTERVAL=10
MAX_RETRIES=5

# Language
DEFAULT_LANGUAGE=es

# JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=[generate a secure random string]
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=WARNING
LOG_VERBOSE=false

SERVER_NAME=TrakCare Offline
